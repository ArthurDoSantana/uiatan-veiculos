# ============================================
# CONSULTA DE PLACA (OPCIONAL)
# ============================================
# A consulta por placa depende de um provedor externo.
# Use {plate} para interpolar a placa na URL.
# Exemplo: PLATE_LOOKUP_API_URL="https://api.seu-provedor.com/placa/{plate}"
# Opcional: se informar apenas PLATE_LOOKUP_API_TOKEN, o sistema usa
# automaticamente o provedor padrao da Invertexto.
PLATE_LOOKUP_API_URL=""
PLATE_LOOKUP_API_TOKEN=""

